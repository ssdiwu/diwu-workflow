{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/user_prompt_submit.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/session_start.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/pre_tool_use_bash.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/subagent_start.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/subagent_stop.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/stop_blocking.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/post_tool_json_validate.py 2>/dev/null||true"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/post_tool_json_validate.py 2>/dev/null||true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/context_monitor.py 2>/dev/null||true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/scripts/pre_compact.py 2>/dev/null||true"
          }
        ]
      }
    ]
  }
}
